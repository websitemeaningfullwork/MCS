# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Community links (optional — buttons are hidden until set)
NEXT_PUBLIC_COMMUNITY_FACEBOOK_URL=
NEXT_PUBLIC_COMMUNITY_WHATSAPP_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # SERVER ONLY — never prefix with NEXT_PUBLIC_

# Distributed rate limiting (STRONGLY recommended in production).
# Without these the limiter falls back to per-instance memory, which on a
# serverless/multi-instance host (Vercel) means login, signup, password-reset,
# contact and payment throttles are only enforced per lambda — i.e. barely at
# all. Set both to enable the shared Redis counter (no npm dependency; the code
# talks to the Upstash REST API with fetch). Leave blank for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (optional — contact/admin email notifications). Leave RESEND_API_KEY
# blank to disable email entirely; contact messages are still stored in the DB.
RESEND_API_KEY=
RESEND_FROM="MCA <onboarding@resend.dev>"
CONTACT_NOTIFICATION_TO=      # where contact-form notifications are sent (defaults to SITE.email)
